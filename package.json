{
  "name": "asfion-app",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "postinstall": "patch-package",
    "eas:login": "eas login",
    "eas:register-ios": "eas device:create",
    "eas:build:preview:ios": "eas build --profile preview --platform ios",
    "eas:build:preview:android": "eas build --profile preview --platform android",
    "eas:build:sim:ios": "eas build --profile preview-sim --platform ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "expo": "~54.0.0",
    "expo-image-picker": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-print": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "13.15.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.1.0",
    "@types/uuid": "^9.0.8",
    "babel-preset-expo": "~13.0.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "patch-package": "^8.0.0",
    "postinstall-postinstall": "^2.1.0",
    "typescript": "~5.6.0"
  }
}
