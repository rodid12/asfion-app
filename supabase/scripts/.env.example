# Copia este archivo a `.env` y completá los valores.
# Este archivo .env NO debe commitearse a git.
#
# Es para SCRIPTS de admin (bootstrap_auth_users.py, etc.). NO es lo mismo
# que el .env.local de la app mobile — la app NUNCA tiene esta key.
#
# NOMENCLATURA: Supabase cambió el naming hace poco.
#   - Lo que en la UI nueva aparece como "Secret key" (sb_secret_...) es lo
#     que antes se llamaba "service_role key". Sirve igual para esto.
#   - Si tu dashboard muestra "Legacy API keys", podés usar la
#     service_role original — también funciona.
# El nombre de la variable acá (SUPABASE_SERVICE_ROLE_KEY) lo dejamos por
# convención, pero acepta cualquiera de las dos formas.

SUPABASE_URL=https://xxxxx.supabase.co

# Pegar acá la "Secret key" del dashboard (Settings → API → Secret keys →
# Create new secret key). Empieza con sb_secret_... o con eyJ... (legacy).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Password inicial para los 16 usuarios. Cada uno la cambia después.
# Mínimo 6 caracteres.
INITIAL_PASSWORD=ganaderas2024
