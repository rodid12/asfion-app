{
  "expo": {
    "name": "ASFION",
    "slug": "asfion-app",
    "version": "0.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#081C28"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.asfion.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ASFION usa tu ubicación para registrar dónde se carga cada evento del campo."
      }
    },
    "android": {
      "package": "com.asfion.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D2939"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-location"
    ],
    "extra": {
      "eas": {
        "projectId": "99d27bea-3e12-4c60-845c-2e68e81ff648"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/99d27bea-3e12-4c60-845c-2e68e81ff648"
    }
  }
}
