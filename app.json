{
  "expo": {
    "name": "ASFION",
    "slug": "asfion-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.asfion.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ASFION usa tu ubicación para registrar dónde se carga cada evento del campo."
      }
    },
    "android": {
      "package": "com.asfion.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {},
    "plugins": [
      "expo-secure-store",
      "expo-location"
    ],
    "extra": {
      "eas": {
        "projectId": "99d27bea-3e12-4c60-845c-2e68e81ff648"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/99d27bea-3e12-4c60-845c-2e68e81ff648"
    }
  }
}
