# Copia este archivo a .env.local y completá los valores.
# .env.local NO debe commitearse a git (ya está en .gitignore).
#
# Las dos variables son para el SupabaseBackend. Si no las definís y
# la app intenta usar kind="supabase", va a tirar un error explícito.
#
# Cómo obtenerlas:
#   1. Crear proyecto en https://supabase.com
#   2. Settings → API
#   3. Copiar "Project URL" y "anon public key"

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
